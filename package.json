{
  "name": "hex-adhd-prep",
  "version": "0.0.1",
  "description": "ADHD diagnostic SaaS",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cd apps/web && pnpm dev",
    "build": "cd apps/web && pnpm build",
    "test": "cd apps/web && jest",
    "test:coverage": "cd apps/web && jest --coverage",
    "type-check": "cd apps/web && tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.0.1",
    "@typescript-eslint/parser": "8.0.1",
    "eslint": "9.16.0",
    "prettier": "3.4.0",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "typescript-eslint": "8.59.1"
  }
}
